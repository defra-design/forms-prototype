{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<h1 class="govuk-heading-l">Check answers page overview</h1>

<form class="form" action="/titan-mvp-1.2/form-editor/listing" method="post">
  {{ govukSummaryList({
    rows: [
      {
        key: {
          text: "Declaration text (optional)",
          classes: "govuk-summary-list__width40"
        },
        value: {
          html: '<a class="govuk-link govuk-link--no-visited-state" href="/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=declaration" id="declaration-action">Add declaration text</a>'
        },
        actions: { items: [] }
      },
      {
        key: {
          text: "Confirmation email" if (data and data.savedAnswersEnabled === "yes") else "Confirmation email (optional)",
          classes: "govuk-summary-list__width40"
        },
        value: {
          html: '<a class="govuk-link govuk-link--no-visited-state" href="/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=confirmation-email" id="confirmation-email-action">Turn off confirmation emails</a>'
        },
        actions: { items: [] }
      },
      {
        key: {
          text: "Reference number (optional)",
          classes: "govuk-summary-list__width40"
        },
        value: {
          html: '<a class="govuk-link govuk-link--no-visited-state" href="/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=reference-number" id="reference-number-action">Turn on the reference number</a>'
        },
        actions: { items: [] }
      },
      {
        key: {
          text: "Sections (optional)",
          classes: "govuk-summary-list__width40"
        },
        value: {
          html: '<a class="govuk-link govuk-link--no-visited-state" href="/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=sections" id="sections-action">Add and organise sections</a>'
        },
        actions: { items: [] }
      },
      {
        key: {
          html: '<span id="user-feedback">User feedback (optional)</span>',
          classes: "govuk-summary-list__width40"
        },
        value: {
          html: '<a class="govuk-link govuk-link--no-visited-state" href="/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=feedback" id="user-feedback-action">Remove the GOV.UK feedback page</a>'
        },
        actions: { items: [] }
      },
      {
        key: {
          text: "Saved answers (optional)",
          classes: "govuk-summary-list__width40"
        },
        value: {
          html: '<a class="govuk-link govuk-link--no-visited-state" href="/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=saved-answers" id="saved-answers-action">Let users save their answers</a>'
        },
        actions: { items: [] }
      }
    ]
  }) }}

  <a href="#tab-one-check-answers" class="govuk-skip-link" style="margin-bottom: 30px!important;" data-module="govuk-skip-link">
    Skip to page preview
  </a>
</form>

{# {% from "govuk/components/details/macro.njk" import govukDetails %}
<hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible"
>
{{ govukDetails({
  classes: "govuk-!-margin-top-6",
  summaryText: "Declarations and sections",
  html: "<h2 class='govuk-heading-m'>Declaration</h2><p class='govuk-body'>A declaration allows users to confirm that they have understood or agreed to something before they submit an online form.</p><p class='govuk-body'>When you add a declaration to the check answers page, it appears at the bottom of the page.</p><h2 class='govuk-heading-m'>Sections</h2><p class='govuk-body'>You can group related pages into sections to help break up particularly long pages. <p class='govuk-body'>When you add sections to the check answers page, each section appears with its own heading, making it easier for people to review their answers by topic.</p>"
}) }} #}


<script>
    // Load sections data and update the display
  document.addEventListener('DOMContentLoaded', function() {
    fetch('/titan-mvp-1.2/form-editor/check-answers/get-session-data')
      .then(response => response.json())
      .then(data => {
        const declarationAction = document.getElementById('declaration-action');
        const sectionsAction = document.getElementById('sections-action');
        const confirmationEmailAction = document.getElementById('confirmation-email-action');
        const referenceNumberAction = document.getElementById('reference-number-action');
        const userFeedbackAction = document.getElementById('user-feedback-action');
        const savedAnswersAction = document.getElementById('saved-answers-action');

        if (declarationAction && data.declarationOption === 'yes-declaration' && data.declarationText && data.declarationText.trim() !== '') {
          declarationAction.textContent = 'Change';
          declarationAction.href = '/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=declaration';
        }

        if (sectionsAction && data.sections && data.sections.length > 0) {
          sectionsAction.textContent = 'Change';
          sectionsAction.href = '/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=sections';
        }

        if (confirmationEmailAction && data.confirmationEmailEnabled === 'no') {
          confirmationEmailAction.textContent = 'Turn on confirmation emails';
          confirmationEmailAction.href = '/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=confirmation-email';
        }

        if (referenceNumberAction && data.referenceNumberEnabled === 'yes') {
          referenceNumberAction.textContent = 'Turn off the reference number';
          referenceNumberAction.href = '/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=reference-number';
        }

        if (userFeedbackAction && data.feedbackPageEnabled === 'no') {
          userFeedbackAction.textContent = 'Add the GOV.UK feedback page';
          userFeedbackAction.href = '/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=feedback';
        }

        if (savedAnswersAction && data.savedAnswersEnabled === 'yes') {
          savedAnswersAction.textContent = 'Change';
          savedAnswersAction.href = '/titan-mvp-1.2/form-editor/check-answers/settings-modular?tab=saved-answers';
        }
      })
      .catch(function() {});
  });
</script>