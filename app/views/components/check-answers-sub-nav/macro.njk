{% macro checkAnswersSubNav(currentTab, showDeclarationTab, showSectionsTab, baseUrl) %}
<nav class="moj-sub-navigation check-answers-sub-nav" aria-label="Sub navigation">
  <ul class="moj-sub-navigation__list" id="nav-list-{{ currentTab }}">
    <li class="moj-sub-navigation__item">
      <a class="moj-sub-navigation__link {% if currentTab == 'page-settings' %}moj-sub-navigation__link--active{% endif %}"
         {% if currentTab == 'page-settings' %}aria-current="page"{% endif %}
         href="{{ baseUrl }}">
        Page overview
      </a>
    </li>
    {% if showDeclarationTab %}
    <li class="moj-sub-navigation__item">
      <a class="moj-sub-navigation__link {% if currentTab == 'declaration' %}moj-sub-navigation__link--active{% endif %}"
         {% if currentTab == 'declaration' %}aria-current="page"{% endif %}
         href="{{ baseUrl }}?tab=declaration">
        Declaration
      </a>
    </li>
    {% endif %}
    <li class="moj-sub-navigation__item">
      <a class="moj-sub-navigation__link {% if currentTab == 'confirmation-email' %}moj-sub-navigation__link--active{% endif %}"
         {% if currentTab == 'confirmation-email' %}aria-current="page"{% endif %}
         href="{{ baseUrl }}?tab=confirmation-email">
        Confirmation email
      </a>
    </li>
    <li class="moj-sub-navigation__item">
      <a class="moj-sub-navigation__link {% if currentTab == 'reference-number' %}moj-sub-navigation__link--active{% endif %}"
         {% if currentTab == 'reference-number' %}aria-current="page"{% endif %}
         href="{{ baseUrl }}?tab=reference-number">
        Reference number
      </a>
    </li>
    {% if showSectionsTab %}
    <li class="moj-sub-navigation__item">
      <a class="moj-sub-navigation__link {% if currentTab == 'sections' %}moj-sub-navigation__link--active{% endif %}"
         {% if currentTab == 'sections' %}aria-current="page"{% endif %}
         href="{{ baseUrl }}?tab=sections">
        Sections
      </a>
    </li>
    {% endif %}
    <li class="moj-sub-navigation__item">
      <a class="moj-sub-navigation__link {% if currentTab == 'feedback' %}moj-sub-navigation__link--active{% endif %}"
         {% if currentTab == 'feedback' %}aria-current="page"{% endif %}
         href="{{ baseUrl }}?tab=feedback">
        User feedback
      </a>
    </li>
    <li class="moj-sub-navigation__item">
      <a class="moj-sub-navigation__link {% if currentTab == 'saved-answers' %}moj-sub-navigation__link--active{% endif %}"
         {% if currentTab == 'saved-answers' %}aria-current="page"{% endif %}
         href="{{ baseUrl }}?tab=saved-answers">
        Saved answers
      </a>
    </li>
  </ul>
</nav>
{% endmacro %}